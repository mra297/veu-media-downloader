{
  "name": "veu-media-downloader",
  "version": "1.0.2",
  "description": "Veu's multi-platform video downloader",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64 --dir",
    "dist": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.veu.media-downloader",
    "productName": "Veu Media Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "preload-update.js",
      "server.js",
      "engine.js",
      "capcut-injector.js",
      "tray.js",
      "public/**",
      "sounds/**",
      "icon.ico",
      "icon.png",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Veu Media Downloader"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mra297",
        "repo": "veu-media-downloader",
        "releaseType": "release"
      }
    ]
  }
}
